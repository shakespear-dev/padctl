# Maintainer: padctl maintainers
pkgname=padctl
pkgver=0.1.0
pkgrel=1
pkgdesc="HID gamepad remapper — declarative TOML config, uinput output"
arch=('x86_64' 'aarch64')
url="https://github.com/example/padctl"
license=('MIT')
depends=()
makedepends=()

_archive="${pkgname}-v${pkgver}-$(uname -m)-linux-musl"
source=("${_archive}.tar.gz::${url}/releases/download/v${pkgver}/${_archive}.tar.gz")
sha256sums=('SKIP')

package() {
    cd "${_archive}"

    install -Dm755 bin/padctl "${pkgdir}/usr/bin/padctl"

    install -Dm644 install/padctl.service \
        "${pkgdir}/usr/lib/systemd/system/padctl.service"

    install -Dm644 install/99-padctl.rules \
        "${pkgdir}/usr/lib/udev/rules.d/99-padctl.rules"

    while IFS= read -r -d '' toml; do
        install -Dm644 "${toml}" "${pkgdir}/usr/share/padctl/${toml}"
    done < <(find devices -name '*.toml' -print0)

    install -Dm644 contrib/aur/PKGBUILD "${pkgdir}/usr/share/licenses/${pkgname}/PKGBUILD"
}
